# S3 path for bad records — shared with the batch pipeline so all bad data lands in one place.
# The consumer will automatically create a sub-prefix  source=kafka/ingest_date=YYYY-MM-DD/
# so stream and batch records are easy to tell apart even in the same bucket.
S3_BAD_OUTPUT=s3://graph-based-transaction-fraud/fraud/bad-transactions/
